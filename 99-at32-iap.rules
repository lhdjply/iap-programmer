# AT32 HID IAP Programmer udev rules
# Copy this file to /etc/udev/rules.d/ and reload rules:
# sudo cp 99-at32-iap.rules /etc/udev/rules.d/
# sudo udevadm control --reload-rules
# sudo udevadm trigger

# AT32 HID IAP Device (VID: 0x2E3C, PID: 0xAF01)
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="2e3c", ATTRS{idProduct}=="af01", MODE="0666"
SUBSYSTEM=="usb", ATTRS{idVendor}=="2e3c", ATTRS{idProduct}=="af01", MODE="0666"
